# GoodMem
GOODMEM_API_KEY=your_goodmem_api_key_here

# Sampling / LLM provider API keys (set based on your chosen provider)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Voyage AI (semantic reranking)
# VOYAGE_API_KEY=pa-your_voyage_api_key_here

# Database (required by docker-compose.yml)
QURAN_MCP_DB_PASSWORD=change_me
